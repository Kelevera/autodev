# autodev configuration — copy to .env and adjust.
# Defaults favor free local Ollama (no API key required).

AUTODEV_LLM_PROVIDER=ollama
AUTODEV_MODEL=qwen2.5-coder:7b
# AUTODEV_BASE_URL=http://localhost:11434

# --- Hosted providers instead ---
# AUTODEV_LLM_PROVIDER=anthropic
# AUTODEV_API_KEY=sk-ant-...
# AUTODEV_MODEL=claude-sonnet-5
#
# AUTODEV_LLM_PROVIDER=openai
# AUTODEV_API_KEY=sk-...
# AUTODEV_MODEL=gpt-4o-mini
# AUTODEV_BASE_URL=https://api.openai.com/v1   # or any OpenAI-compatible server

AUTODEV_MAX_TOKENS=4096
AUTODEV_DB_PATH=autodev.db
AUTODEV_REPO_PATH=.
AUTODEV_SRC_DIR=src
AUTODEV_TESTS_DIR=tests
AUTODEV_MAX_JOBS_PER_RUN=3
